# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Drizzle
DATABASE_URL="postgresql://postgres:alexvboy@localhost:5432/eaglevents"
# Production database URL (used by `pnpm prod <script>`)
# Update password/host as needed
DATABASE_URL_PROD="postgresql://postgres:alexvboy@localhost:5432/eagleventsprod"

# Development server origin (used for SSR/links in dev)
DEV_SERVER="http://localhost:3015"
# Production dev server origin (used by `pnpm prod dev`)
DEV_SERVER_PROD="http://localhost:3024"
# Base URL used by NextAuth for callbacks (adjust if running on another port)
NEXTAUTH_URL="http://localhost:3000"

# NextAuth (same secret used in dev & prod)
NEXTAUTH_SECRET="changeme-nextauthsecret-same-for-dev-and-prod"
